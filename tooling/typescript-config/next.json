{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "Next.js",
	"extends": "./react.json",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowJs": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"@presethub/ui": ["../packages/ui/src"],
			"@presethub/types": ["../packages/types/src"],
			"@presethub/config": ["../packages/config/src"]
		}
	},
	"exclude": ["node_modules", ".next"],
	"include": ["src/**/*.ts", "src/**/*.tsx", "next-env.d.ts"]
}
