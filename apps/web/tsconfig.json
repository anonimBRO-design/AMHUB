{
  "extends": "@presethub/typescript-config/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@presethub/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@presethub/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@presethub/types/*": [
        "../../packages/types/src/*"
      ],
      "@presethub/types": [
        "../../packages/types/src/index.ts"
      ],
      "@presethub/config/*": [
        "../../packages/config/src/*"
      ],
      "@presethub/config": [
        "../../packages/config/src/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
